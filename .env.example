# ===== KIS OpenAPI (한국투자증권) — 주식 계좌 =====
# docs/kis-setup.md 참고하여 발급. 수급/시총순위/주가 조회에 사용
KIS_APP_KEY=발급받은_앱키
KIS_APP_SECRET=발급받은_앱시크릿
KIS_ACCOUNT_NO=계좌번호(모의투자, 예: 50000000-01)
# true=모의투자 도메인, false=실전투자 도메인 (주식/선물 공통 적용)
KIS_IS_MOCK=true

# ===== KIS OpenAPI — 선물옵션 계좌 (선택) =====
# 선물 모의투자 앱을 별도 등록하면 App Key/Secret이 주식과 다르게 발급된다.
# 채우면 선물/콜/풋의 시세·호가·체결·잔고 조회가 가능. 미입력 시 주식 키로 폴백.
# 주의: 선물 키가 있어도 선물/옵션 "투자자 수급"은 KIS 미제공이라 받을 수 없다(외부 소스, ROADMAP Task 027).
KIS_FUTURES_APP_KEY=
KIS_FUTURES_APP_SECRET=
KIS_FUTURES_ACCOUNT_NO=
